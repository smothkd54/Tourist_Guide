# Pushkinskaya Street Explorer — Environment Configuration
# Copy to .env and edit for your deployment.

# CORS origins (pipe-delimited)
CORS_ORIGINS=http://localhost:*|http://127.0.0.1:*

# Gunicorn worker count (2x CPU cores is a good default)
GUNICORN_WORKERS=2

# Model path inside the container
MODEL_PATH=/app/models/landmark_classifier.keras

# Log directory inside the container
LOG_DIR=/app/logs
